class Solution {
    public long sumAndMultiply(int n) {
      if(n==0) return 0;
      String s=String.valueOf(n);
      int sum=0;
      StringBuilder sb=new StringBuilder();
      while(n!=0){
        sum+=n%10;
        if(n%10!=0){
            sb.append(n%10);
        }
        n=n/10;
      }  
      System.out.println();
      return Long.parseLong(sb.reverse().toString())*sum;
    }
}
